<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
	<metadata>
		<id>Afrodit.Uwp.Themes</id>
		<version>1.0.0</version>
		<title>Afrodit UI - Core Themes</title>
		<authors>Alex Falcon Flores</authors>
		<owners>Afrodit</owners>
		<requireLicenseAcceptance>false</requireLicenseAcceptance>
		<license type="expression">MIT</license>
		<icon>Assets\icon.png</icon>
		<readme>readme.md</readme>
		<projectUrl>https://github.com/alexfalconflores/afrodit-uwp</projectUrl>
		<repository type="git" url="https://github.com/alexfalconflores/afrodit-uwp" branch="main" />
		<summary>Librería de estilos base y Design Tokens para el ecosistema Afrodit.</summary>
		<description>Librería de estilos base y Design Tokens para el ecosistema Afrodit. Incluye paleta semántica, tipografía moderna y una familia completa de botones y entradas optimizadas para UWP.</description>
		<releaseNotes>
			Se lanza la versión 1.0.0 de Afrodit.Uwp.Themes, estableciendo la base de estilos para el ecosistema Afrodit en UWP. Esta versión incluye una paleta de colores semántica, tipografía moderna y una familia completa de estilos para botones y entradas, optimizados para aplicaciones UWP. Con esta librería, los desarrolladores pueden crear interfaces consistentes y atractivas que se integren perfectamente con el diseño Fluent.
		</releaseNotes>
		<copyright>Copyright 2026 Alex Falcon Flores</copyright>
		<tags>uwp winui fluent themes xaml styles afrodit controls</tags>

		<dependencies>
			<group targetFramework="netcore50">
				<dependency id="Microsoft.UI.Xaml" version="2.8.6" />
			</group>
		</dependencies>
	</metadata>

	<files>
		<file src="..\Assets\icon.png" target="Assets\" />
		<file src="readme.md" target="readme.md" />
			  
		<file src="bin\x64\Release\Afrodit.Uwp.Themes.dll" target="lib\netcore50" />
		<file src="bin\x64\Release\Afrodit.Uwp.Themes.pri" target="lib\netcore50" />
		<file src="bin\x64\Release\Afrodit.Uwp.Themes.pdb" target="lib\netcore50" />

		<file src="bin\x64\Release\Afrodit.Uwp.Themes\*.xaml" target="lib\netcore50\Afrodit.Uwp.Themes" />
		<file src="bin\x64\Release\Afrodit.Uwp.Themes\*.xml" target="lib\netcore50\Afrodit.Uwp.Themes" />
		<file src="bin\x64\Release\Afrodit.Uwp.Themes\Dictionaries\*.xaml" target="lib\netcore50\Afrodit.Uwp.Themes\Dictionaries" />
	</files>
</package>
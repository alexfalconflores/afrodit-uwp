<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:Double x:Key="AfroditTextSizeDisplay">42</x:Double>
    <x:Double x:Key="AfroditTextSizeHeader">32</x:Double>
    <x:Double x:Key="AfroditTextSizeTitle">24</x:Double>
    <x:Double x:Key="AfroditTextSizeSubtitle">20</x:Double>
    <x:Double x:Key="AfroditTextSizeBody">14</x:Double>
    <x:Double x:Key="AfroditTextSizeCaption">12</x:Double>
    <Style x:Key="AfroditHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource AfroditTextSizeHeader}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{ThemeResource SystemControlPageTextBaseHighBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="AfroditTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource AfroditTextSizeTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource SystemControlPageTextBaseHighBrush}" />
    </Style>

    <Style x:Key="AfroditBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource AfroditTextSizeBody}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource SystemControlPageTextBaseHighBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <Style x:Key="AfroditSecondaryBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource AfroditTextSizeBody}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
    </Style>

    <Style x:Key="AfroditCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource AfroditTextSizeCaption}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
    </Style>

    <Style
        x:Key="AfroditDangerTextStyle"
        BasedOn="{StaticResource AfroditBodyStyle}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource AfroditDangerBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style
        x:Key="AfroditWarningTextStyle"
        BasedOn="{StaticResource AfroditBodyStyle}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource AfroditWarningBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

</ResourceDictionary>
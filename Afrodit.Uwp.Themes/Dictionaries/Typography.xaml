<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:Double x:Key="TextSizeDisplay">42</x:Double>
    <x:Double x:Key="TextSizeHeader">32</x:Double>
    <x:Double x:Key="TextSizeTitle">24</x:Double>
    <x:Double x:Key="TextSizeSubtitle">20</x:Double>
    <x:Double x:Key="TextSizeBody">14</x:Double>
    <x:Double x:Key="TextSizeCaption">12</x:Double>

    <Style x:Key="HeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource TextSizeHeader}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{ThemeResource SystemControlPageTextBaseHighBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="TitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource TextSizeTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource SystemControlPageTextBaseHighBrush}" />
    </Style>

    <Style x:Key="BodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource TextSizeBody}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource SystemControlPageTextBaseHighBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <Style x:Key="SecondaryBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource TextSizeBody}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
    </Style>

    <Style x:Key="CaptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource TextSizeCaption}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
    </Style>

    <Style
        x:Key="DangerTextStyle"
        BasedOn="{StaticResource BodyStyle}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource DangerBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style
        x:Key="WarningTextStyle"
        BasedOn="{StaticResource BodyStyle}"
        TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource WarningBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

</ResourceDictionary>
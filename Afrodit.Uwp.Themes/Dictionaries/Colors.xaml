<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:Double x:Key="AfroditIconSizeSmall">32</x:Double>
    <x:Double x:Key="AfroditIconSizeMedium">36</x:Double>
    <x:Double x:Key="AfroditIconSizeLarge">48</x:Double>
    <x:Double x:Key="AfroditIconSizeHuge">64</x:Double>

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="AfroditDangerBrush" Color="#E81123" />
            <SolidColorBrush x:Key="AfroditDangerTextBrush" Color="#FFFFFF" />
            <Color x:Key="AfroditDangerHoverColor">#C50F1F</Color>
            <Color x:Key="AfroditDangerPressedColor">#A20025</Color>

            <SolidColorBrush x:Key="AfroditSuccessBrush" Color="#107C10" />
            <Color x:Key="AfroditSuccessHoverColor">#128E12</Color>
            <Color x:Key="AfroditSuccessPressedColor">#0E6A0E</Color>

            <Color x:Key="AfroditSubtleHoverColor">#1AFFFFFF</Color>
            <Color x:Key="AfroditSubtlePressedColor">#33FFFFFF</Color>
            <Color x:Key="AfroditSubtleHoverTextColor">#FFFFFF</Color>

            <SolidColorBrush x:Key="AfroditWarningBrush" Color="#FF8C00" />
            <Color x:Key="AfroditWarningHoverColor">#FF9A1A</Color>
            <Color x:Key="AfroditWarningPressedColor">#E67E00</Color>

            <SolidColorBrush x:Key="AfroditInfoBrush" Color="#0078D4" />
            <Color x:Key="AfroditInfoHoverColor">#1A86D9</Color>
            <Color x:Key="AfroditInfoPressedColor">#006ABC</Color>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="AfroditDangerBrush" Color="#D13438" />
            <SolidColorBrush x:Key="AfroditDangerTextBrush" Color="#FFFFFF" />
            <Color x:Key="AfroditDangerHoverColor">#B81D23</Color>
            <Color x:Key="AfroditDangerPressedColor">#A20025</Color>

            <SolidColorBrush x:Key="AfroditSuccessBrush" Color="#107C10" />
            <Color x:Key="AfroditSuccessHoverColor">#0F700F</Color>
            <Color x:Key="AfroditSuccessPressedColor">#0B5A0B</Color>

            <Color x:Key="AfroditSubtleHoverColor">#0D000000</Color>
            <Color x:Key="AfroditSubtlePressedColor">#1A000000</Color>
            <Color x:Key="AfroditSubtleHoverTextColor">#000000</Color>

            <SolidColorBrush x:Key="AfroditWarningBrush" Color="#FF8C00" />
            <Color x:Key="AfroditWarningHoverColor">#E67E00</Color>
            <Color x:Key="AfroditWarningPressedColor">#CC7000</Color>

            <SolidColorBrush x:Key="AfroditInfoBrush" Color="#0078D4" />
            <Color x:Key="AfroditInfoHoverColor">#006ABC</Color>
            <Color x:Key="AfroditInfoPressedColor">#005A9E</Color>
        </ResourceDictionary>

        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="AfroditDangerBrush" Color="{ThemeResource SystemColorButtonFaceColor}" />
            <SolidColorBrush x:Key="AfroditDangerTextBrush" Color="{ThemeResource SystemColorButtonTextColor}" />

            <SolidColorBrush x:Key="AfroditSuccessBrush" Color="{ThemeResource SystemColorButtonFaceColor}" />

            <SolidColorBrush x:Key="AfroditWarningBrush" Color="{ThemeResource SystemColorButtonFaceColor}" />
            <SolidColorBrush x:Key="AfroditInfoBrush" Color="{ThemeResource SystemColorButtonFaceColor}" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
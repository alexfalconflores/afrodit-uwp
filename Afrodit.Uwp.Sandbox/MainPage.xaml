<Page
    x:Class="Afrodit.Uwp.Sandbox.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:afrodit="using:Afrodit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Afrodit.Uwp.Sandbox"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winui="using:Microsoft.UI.Xaml.Controls"
    winui:BackdropMaterial.ApplyToRootOrPageBackground="True"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  TitleBar  -->
            <RowDefinition Height="*" />
            <!--  NavigationView  -->
        </Grid.RowDefinitions>

        <afrodit:TitleBar
            x:Name="AppTitleBar"
            AppIconSource="/Assets/Square150x150Logo.scale-200.png"
            AppName="Afrodit Sandbox"
            BackRequested="AppTitleBar_BackRequested"
            PaneToggleRequested="AppTitleBar_PaneToggleRequested"
            Size="Tall"
            Subtitle="Preview">

            <AutoSuggestBox
                Width="280"
                VerticalAlignment="Center"
                PlaceholderText="Buscar en Nokana..."
                QueryIcon="Find" />

            <afrodit:TitleBar.PaneLeftContent>
                <winui:MenuBar Margin="8,0,0,0" Background="Transparent">
                    <winui:MenuBarItem Title="Archivo">
                        <MenuFlyoutItem Icon="Add" Text="Nueva Nota" />
                        <MenuFlyoutItem Icon="Sync" Text="Sincronizar" />
                    </winui:MenuBarItem>
                    <winui:MenuBarItem Title="Editar">
                        <MenuFlyoutItem Icon="Undo" Text="Deshacer" />
                    </winui:MenuBarItem>
                </winui:MenuBar>
            </afrodit:TitleBar.PaneLeftContent>

            <afrodit:TitleBar.PaneRightContent>
                <StackPanel
                    Margin="0,0,16,0"
                    Orientation="Horizontal"
                    Spacing="16">
                    <Button
                        VerticalAlignment="Center"
                        Content="Actualizar a Pro"
                        Style="{ThemeResource AccentButtonStyle}" />
                    <winui:PersonPicture
                        Height="32"
                        VerticalAlignment="Center"
                        DisplayName="Ingeniero" />
                </StackPanel>
            </afrodit:TitleBar.PaneRightContent>

        </afrodit:TitleBar>

        <afrodit:ListDetailsView
            Grid.Row="1"
            InlineBackButtonVisibility="Visible"
            ItemsSource="{x:Bind Notes, Mode=OneWay}"
            NoSelectionContent="Selecciona una nota para empezar a escribir ✍️">

            <afrodit:ListDetailsView.ItemTemplate>
                <DataTemplate x:DataType="local:Note">
                    <StackPanel Padding="16,12" Spacing="4">
                        <TextBlock Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{x:Bind Date}" />
                    </StackPanel>
                </DataTemplate>
            </afrodit:ListDetailsView.ItemTemplate>

            <afrodit:ListDetailsView.DetailsTemplate>
                <DataTemplate x:DataType="local:Note">
                    <Grid Padding="32,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBox
                            Grid.Row="0"
                            FontSize="40"
                            FontWeight="Bold"
                            PlaceholderText="Título de la nota"
                            Text="{x:Bind Title, Mode=TwoWay}" />

                        <TextBox
                            Grid.Row="1"
                            Margin="0,16,0,0"
                            AcceptsReturn="True"
                            PlaceholderText="Escribe lo que estás pensando..."
                            Text="{x:Bind Content, Mode=TwoWay}"
                            TextWrapping="Wrap" />
                    </Grid>
                </DataTemplate>
            </afrodit:ListDetailsView.DetailsTemplate>
        </afrodit:ListDetailsView>

        <!--<winui:NavigationView
            x:Name="SandboxNavView"
            Grid.Row="1"
            Margin="0,0,0,0"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False">
            <winui:NavigationView.MenuItems>
                <winui:NavigationViewItem Content="Inicio" Icon="Home" />
                <winui:NavigationViewItem Content="Componentes" Icon="Library" />
            </winui:NavigationView.MenuItems>

            <Frame>
                <StackPanel Orientation="Vertical" Spacing="12">
                    <TextBlock
                        x:Name="StatusTextBlock"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Style="{ThemeResource TitleTextBlockStyle}"
                        Text="¡Esperando interacción...!" />
                    <Button
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="OnOpenOverlayClicked"
                        Content="Lanzar Overlay de Prueba"
                        Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Frame>
        </winui:NavigationView>-->
    </Grid>
</Page>

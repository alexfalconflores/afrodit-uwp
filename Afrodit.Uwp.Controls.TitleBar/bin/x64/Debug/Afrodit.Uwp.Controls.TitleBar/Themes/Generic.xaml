<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:converters="using:Afrodit.WinUI.Extensions.Converters"
    xmlns:extensions="using:Afrodit.WinUI.Extensions"
    xmlns:local="using:Afrodit.WinUI.Controls"
    xmlns:winui="using:Microsoft.UI.Xaml.Controls">

    <converters:EnumToGridLengthConverter x:Key="SizeToGridLengthConverter" />
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

    <Style TargetType="local:TitleBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:TitleBar">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Size, Converter={StaticResource SizeToGridLengthConverter}}" />
                        </Grid.RowDefinitions>

                        <Grid x:Name="AppTitleBarGrid" Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="LeftTitleBarMarginColumn" Width="8" />
                                <ColumnDefinition x:Name="TitleContentColumn" Width="Auto" />
                                <ColumnDefinition x:Name="LeftContentColumn" Width="Auto" />
                                <ColumnDefinition x:Name="ContentColumn" Width="*" />
                                <ColumnDefinition x:Name="RightContentColumn" Width="Auto" />
                                <ColumnDefinition x:Name="RightTitleBarMarginColumn" Width="0" />
                            </Grid.ColumnDefinitions>

                            <Grid
                                x:Name="TitleContentGrid"
                                Grid.Column="1"
                                extensions:FrameworkElementExtensions.EnableActualSizeBinding="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Rectangle
                                    Width="32"
                                    Fill="Transparent"
                                    Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsBackButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <Rectangle
                                    Grid.Column="1"
                                    Width="32"
                                    Fill="Transparent"
                                    Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsPaneToggleButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <Image
                                    x:Name="AppIconImage"
                                    Grid.Column="2"
                                    Width="16"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Source="{TemplateBinding AppIconSource}"
                                    Visibility="{TemplateBinding IsAppIconVisible}" />

                                <TextBlock
                                    x:Name="AppNameTextBlock"
                                    Grid.Column="4"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Text="{TemplateBinding AppName}" />

                                <TextBlock
                                    x:Name="SubtitleTextBlock"
                                    Grid.Column="5"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="Gray"
                                    Text="{TemplateBinding Subtitle}"
                                    Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsSubtitleVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                        </Grid>

                        <Grid x:Name="IAppTitleBarGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="ILeftTitleBarMarginColumn" Width="8" />
                                <ColumnDefinition x:Name="ITitleContentColumn" Width="Auto" />
                                <ColumnDefinition x:Name="ILeftContentColumn" Width="Auto" />
                                <ColumnDefinition x:Name="IContentColumn" Width="*" />
                                <ColumnDefinition x:Name="IRightContentColumn" Width="Auto" />
                                <ColumnDefinition x:Name="IRightTitleBarMarginColumn" Width="0" />
                            </Grid.ColumnDefinitions>

                            <StackPanel
                                Grid.Column="1"
                                Width="{Binding ElementName=TitleContentGrid, Path=(extensions:FrameworkElementExtensions.ActualWidth)}"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">

                                <Button
                                    x:Name="GoBackButtonControl"
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,2,0"
                                    Padding="6"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsBackButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <winui:AnimatedIcon
                                        x:Name="BackAnimatedIcon"
                                        Width="16"
                                        Height="16">
                                        <winui:AnimatedIcon.Source>
                                            <animatedvisuals:AnimatedBackVisualSource />
                                        </winui:AnimatedIcon.Source>
                                        <winui:AnimatedIcon.FallbackIconSource>
                                            <winui:SymbolIconSource Symbol="Back" />
                                        </winui:AnimatedIcon.FallbackIconSource>
                                    </winui:AnimatedIcon>
                                </Button>

                                <Button
                                    x:Name="PaneToggleButton"
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,2,0"
                                    Padding="6"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsPaneToggleButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <winui:AnimatedIcon
                                        x:Name="PaneAnimatedIcon"
                                        Width="16"
                                        Height="16">
                                        <winui:AnimatedIcon.Source>
                                            <animatedvisuals:AnimatedGlobalNavigationButtonVisualSource />
                                        </winui:AnimatedIcon.Source>
                                        <winui:AnimatedIcon.FallbackIconSource>
                                            <winui:SymbolIconSource Symbol="GlobalNavigationButton" />
                                        </winui:AnimatedIcon.FallbackIconSource>
                                    </winui:AnimatedIcon>
                                </Button>
                            </StackPanel>

                            <ContentPresenter
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding PaneLeftContent}" />
                            <ContentPresenter
                                Grid.Column="3"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Content}" />
                            <ContentPresenter
                                Grid.Column="4"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding PaneRightContent}" />
                        </Grid>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup>
                                <VisualState>
                                    <VisualState.StateTriggers>
                                        <AdaptiveTrigger MinWindowWidth="0" />
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Target="LeftTitleBarMarginColumn.Width" Value="0" />
                                        <Setter Target="ILeftTitleBarMarginColumn.Width" Value="0" />
                                        <Setter Target="TitleContentGrid.Margin" Value="0,0,0,0" />
                                        <Setter Target="ILeftContent.Margin" Value="0,0,16,0" />
                                        <Setter Target="IRightContent.Margin" Value="16,0,0,0" />
                                    </VisualState.Setters>
                                </VisualState>

                                <VisualState>
                                    <VisualState.StateTriggers>
                                        <AdaptiveTrigger MinWindowWidth="800" />
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Target="LeftTitleBarMarginColumn.Width" Value="8" />
                                        <Setter Target="ILeftTitleBarMarginColumn.Width" Value="8" />
                                        <Setter Target="TitleContentGrid.Margin" Value="0,0,16,0" />
                                        <Setter Target="ILeftContent.Margin" Value="0,0,16,0" />
                                        <Setter Target="IRightContent.Margin" Value="16,0,0,0" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

